@model Argitis.Models.ServicesViewModel

@{
    ViewData["Title"] = Model.Title;
    ViewData["MetaDescription"] = Model.MetaDescription;
    ViewData["MetaKeywords"] = Model.MetaKeywords;
}

<!-- .page-title -->
<div class="page-title">
    <div class="tf-container">
        <div class="row">
            <div class="col-12">
                <h3 class="title">@Model.PageTitle</h3>
                <ul class="breadcrumbs">
                    <li><a href="/">Главная</a></li>
                    <li>Услуги</li>
                </ul>
            </div>
        </div>
    </div>
</div><!-- /.page-title -->
<!-- .main-content -->
<div class="main-content-2">

    <!-- .section-service -->
    <section class="section-service page-our-service tf-spacing-3">
        <div class="tf-container">
            <div class="row">
                <div class="col-12">
                    <div class="heading-section">
                        <h3 class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">@Model.PageHeading</h3>
                        <p class="description text-1 lh-30 wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">@Model.PageDescription</p>
                    </div>
                    <div class="grid-layout-3 multi-item">
                        @foreach (var service in Model.Services)
                        {
                            <div class="service-item style-3 hover-img wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                <div class="content z-5">
                                    <h5 class="title">
                                        <a href="@service.Link">@service.Name</a>
                                    </h5>
                                    <p>@service.Description</p>
                                </div>
                                <div class="image-wrap z-5 relative">
                                    <a href="@service.Link">
                                        <img class="lazyload" data-src="@service.ImageUrl" src="@service.ImageUrl" alt="@service.Name">
                                    </a>
                                </div>
                                <a href="@service.Link" class="tf-btn-link z-5">
                                    <span data-text="Смотреть детали">Смотреть детали</span>
                                    <i class="icon-ArrowRight"></i>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section><!-- /.section-service -->
    <!-- .section-contact -->
    <section class="section-contact">
        <div class="tf-container">
            <div class="row">
                <div class="col-12">
                    <div class="wrap-content">
                        <div class="box-contact">
                            <div class="heading-section text-start">
                                <p class="text-2 sub wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                    Готовы реализовать свои проекты?
                                </p>
                                <h3 class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                    Воспользуйтесь нашими решениями по финансированию.
                                </h3>
                                <p class="description text-1 lh-30 wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                    Мы помогаем вам найти подходящее решение по финансированию. Мы здесь, чтобы поддержать вас.
                                </p>
                            </div>
                            <ul class="list-info">
                                <li class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s"><i class="icon-Envelope"></i> <a href="mailto:contact@groupeargitis.com">contact@groupeargitis.com</a></li>
                                <li class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s"><i class="icon-PhoneCall"></i><a href="tel:+34 610-340-344">+34 610-340-344</a></li>
                                <li class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s"><i class="icon-MapPin"></i>Welserstr. 13-15 (Geisbeegerstr.), 10777 Berlin, Allemagne</li>
                            </ul>
                        </div>
                        <form class="form-consultation wow fadeInRight" data-wow-duration="1000" data-wow-delay="0s" method="post" action="/Home/Appointment">
                            <h4 class="mb-20 text-center">Запросить кредит</h4>
                            <fieldset class="name">
                                <input type="text" name="name" class="tf-input style-1" placeholder="Фамилия и имя" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <fieldset class="phone">
                                <input type="tel" name="phone" class="tf-input style-1" placeholder="Телефон" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <fieldset class="email">
                                <input type="email" name="email" class="tf-input style-1" placeholder="E-mail" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <fieldset class="amount">
                                <input type="number" name="amount" class="tf-input style-1" placeholder="Желаемая сумма" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <fieldset class="period">
                                <input type="text" name="period" class="tf-input style-1" placeholder="Срок (месяцев)" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <button class="tf-btn style-default btn-color-secondary pd-40 boder-8 send-wrap" type="submit">
                                <span>Подтвердить</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section> <!-- /.section-contact -->

</div><!-- /.main-content -->