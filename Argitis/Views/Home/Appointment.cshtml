@model Argitis.Models.LoanRequest

@{
    ViewData["Title"] = "Appointment - GROUPE-ARGITIS";
    ViewData["MetaDescription"] = "Заполните форму заявки на кредит онлайн.";
    ViewData["MetaKeywords"] = "Finance, Loan, Personal loan, Home loan, Mortgage Loan, Auto Credit, Mortgage Credit, Education Financing, Loan information, Requested amount";
}

@section Styles {
    <style>
        /* Стили из вашего HTML */
        .appointment-info {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 10px;
            border-left: 4px solid #114f4f;
        }

        .appointment-calculator-info h4.title {
            color: #114f4f;
            margin-bottom: 15px;
            font-size: 18px;
        }

        .appointment-details p {
            margin-bottom: 10px;
            line-height: 1.6;
            color: #333;
        }

        .appointment-details strong {
            color: #114f4f;
        }

        .appointment-details span {
            color: #114f4f;
            font-weight: bold;
        }

        .pricing-info {
            background: linear-gradient(135deg, #fff5f0 0%, #fff8f0 100%);
            border: 2px solid rgba(60, 33, 14, 0.15);
            border-radius: 12px;
            padding: 25px;
            margin: 25px 0;
            box-shadow: 0 4px 20px rgba(60, 33, 14, 0.08);
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-height: 300px;
        }

            .pricing-info h4 {
                color: #3C210E;
                font-size: 22px;
                font-weight: 700;
                margin-bottom: 15px;
                text-align: center;
                position: relative;
            }

                .pricing-info h4:after {
                    content: '';
                    position: absolute;
                    bottom: -8px;
                    left: 50%;
                    transform: translateX(-50%);
                    width: 50px;
                    height: 2px;
                    background: linear-gradient(90deg, #3C210E, #ff6b35);
                    border-radius: 1px;
                }

        .pricing-description {
            color: #6c757d;
            font-size: 15px;
            line-height: 1.6;
            text-align: center;
            margin-bottom: 20px;
        }

        .service-rates h5 {
            color: #3C210E;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 15px;
            text-align: center;
        }

        .rates-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 12px;
            margin-bottom: 20px;
        }

        .rate-item {
            background: white;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid rgba(60, 33, 14, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s ease;
        }

            .rate-item:hover {
                border-color: rgba(60, 33, 14, 0.3);
                box-shadow: 0 2px 8px rgba(60, 33, 14, 0.1);
                transform: translateY(-1px);
            }

        .service-name {
            color: #3C210E;
            font-size: 14px;
            font-weight: 500;
            flex: 1;
        }

        .rate-price {
            color: #ff6b35;
            font-size: 16px;
            font-weight: 700;
            background: rgba(255, 107, 53, 0.1);
            padding: 6px 12px;
            border-radius: 20px;
            white-space: nowrap;
        }

        .rate-note {
            background: rgba(60, 33, 14, 0.05);
            border-left: 4px solid #ff6b35;
            padding: 15px;
            border-radius: 0 8px 8px 0;
            color: #6c757d;
            font-size: 14px;
            line-height: 1.5;
            margin: 0;
        }

            .rate-note strong {
                color: #3C210E;
            }

        .appointment-info {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border-radius: 16px;
            padding: 40px;
            margin-top: 30px;
            border: 1px solid rgba(60, 33, 14, 0.1);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        }

        .info-content h4 {
            color: #3C210E;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 30px;
            text-align: center;
            position: relative;
        }

            .info-content h4:after {
                content: '';
                position: absolute;
                bottom: -10px;
                left: 50%;
                transform: translateX(-50%);
                width: 60px;
                height: 3px;
                background: linear-gradient(90deg, #3C210E, #6c757d);
                border-radius: 2px;
            }

        .info-steps {
            margin-bottom: 40px;
        }

        .step-item {
            display: flex;
            align-items: flex-start;
            gap: 20px;
            margin-bottom: 30px;
            padding: 20px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
            transition: all 0.3s ease;
        }

            .step-item:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
            }

        .step-number {
            background: linear-gradient(135deg, #3C210E, #6c757d);
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 18px;
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(60, 33, 14, 0.3);
        }

        .step-text h5 {
            color: #3C210E;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .step-text p {
            color: #6c757d;
            font-size: 14px;
            line-height: 1.6;
            margin: 0;
        }

        .contact-info {
            background: linear-gradient(135deg, #3C210E, #495057);
            color: white;
            padding: 25px;
            border-radius: 12px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .contact-info:before {
                content: '';
                position: absolute;
                top: -50%;
                right: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
                animation: float 6s ease-in-out infinite;
            }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0px) rotate(0deg);
            }

            50% {
                transform: translateY(-20px) rotate(180deg);
            }
        }

        .contact-info h5 {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 15px;
            position: relative;
            z-index: 1;
        }

        .contact-info p {
            font-size: 14px;
            line-height: 1.6;
            margin: 0;
            position: relative;
            z-index: 1;
        }

        .contact-info strong {
            color: #ffd700;
            font-weight: 600;
        }

        @@media (max-width: 768px) {
            .appointment-info {
                padding: 25px;
                margin-top: 20px;
            }

            .info-content h4 {
                font-size: 24px;
            }

            .step-item {
                padding: 15px;
                gap: 15px;
            }

            .step-number {
                width: 35px;
                height: 35px;
                font-size: 16px;
            }

            .step-text h5 {
                font-size: 16px;
            }

            .step-text p {
                font-size: 13px;
            }

            .pricing-info {
                padding: 20px;
                margin: 20px 0;
                min-height: 250px;
            }

                .pricing-info h4 {
                    font-size: 20px;
                }

            .pricing-description {
                font-size: 14px;
            }

            .rates-grid {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .rate-item {
                padding: 12px;
                flex-direction: column;
                gap: 8px;
                text-align: center;
            }

            .service-name {
                font-size: 13px;
            }

            .rate-price {
                font-size: 15px;
            }

            .rate-note {
                font-size: 13px;
                padding: 12px;
            }
        }

        .message-alert {
            margin-bottom: 20px;
            border-radius: 8px;
            border: none;
            padding: 15px 20px;
            font-weight: 500;
        }

            .message-alert.alert-success {
                background-color: #d4edda;
                color: #155724;
                border-left: 4px solid #28a745;
            }

            .message-alert.alert-danger {
                background-color: #f8d7da;
                color: #721c24;
                border-left: 4px solid #dc3545;
            }

            .message-alert i {
                margin-right: 8px;
            }

            .message-alert .btn-close {
                background: none;
                border: none;
                font-size: 18px;
                color: inherit;
                opacity: 0.7;
                cursor: pointer;
            }

                .message-alert .btn-close:hover {
                    opacity: 1;
                }
    </style>
}

<div class="main-content-2 page-appointment bg-1">
    <section class="section-book-appointment">
        <div class="tf-container">
            <div class="row">
                <div class="col-12">
                    <div class="wrap-content">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="message-alert alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="fa fa-exclamation-circle"></i> Пожалуйста, исправьте ошибки в форме.
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <form class="form-appointment" id="appointment_form" method="post" asp-action="Appointment">
                            @Html.AntiForgeryToken()

                            <div class="heading-section text-start">
                                <h3>Форма заявки на кредит</h3>
                                <p class="description text-1">
                                    Наш сайт использует несколько мер безопасности для защиты ваших личных данных в любое время.
                                </p>
                            </div>

                            <div class="cols mb-20">
                                <fieldset class="amount">
                                    <input type="number" asp-for="Amount" id="amount" class="tf-input style-1" placeholder="Желаемая сумма" value="@Model.Amount" tabindex="2" aria-required="true" required>
                                    <span asp-validation-for="Amount" class="text-danger"></span>
                                </fieldset>
                                <div class="select-custom">
                                    <select asp-for="Currency" id="currency" class="tf-select" data-default="">
                                        <option disabled selected value="---">Выберите валюту</option>
                                        <option value="EUR">€ EUR</option>
                                        <option value="CHF">₣ CHF</option>
                                        <option value="USD">$ USD</option>
                                        <option value="CAD">$ CAD</option>
                                        <option value="GBP">£ GBP</option>
                                    </select>
                                    <span asp-validation-for="Currency" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="cols mb-20">
                                <fieldset class="period">
                                    <input type="text" asp-for="Period" id="period" class="tf-input style-1" placeholder="Срок (месяцев)" tabindex="2" aria-required="true" required value="@Model.Period">
                                    <span asp-validation-for="Period" class="text-danger"></span>
                                </fieldset>
                                <fieldset class="name">
                                    <input type="text" asp-for="Name" id="name" class="tf-input style-2" placeholder="Фамилия и имя" tabindex="2" aria-required="true" required value="@Model.Name">
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </fieldset>
                            </div>

                            <div class="cols mb-20">
                                <fieldset class="phone">
                                    <input type="number" asp-for="Phone" id="phone" class="tf-input style-1" placeholder="Телефон" tabindex="2" aria-required="true" required value="@Model.Phone">
                                    <span asp-validation-for="Phone" class="text-danger"></span>
                                </fieldset>
                                <fieldset class="address">
                                    <input type="text" asp-for="Address" id="address" class="tf-input style-2" placeholder="Полный адрес" tabindex="2" aria-required="true" required value="@Model.Address">
                                    <span asp-validation-for="Address" class="text-danger"></span>
                                </fieldset>
                            </div>

                            <div class="cols mb-20">
                                <fieldset class="email">
                                    <input type="email" asp-for="Email" id="email" class="tf-input style-1" placeholder="E-mail" tabindex="2" aria-required="true" required value="@Model.Email">
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </fieldset>
                                <fieldset class="email_confirm">
                                    <input type="email" asp-for="EmailConfirm" id="email_confirm" class="tf-input style-1" placeholder="Подтвердите e-mail" tabindex="2" aria-required="true" required value="@Model.EmailConfirm">
                                    <span asp-validation-for="EmailConfirm" class="text-danger"></span>
                                </fieldset>
                            </div>

                            <div class="cols mb-20">
                                <div class="select-custom">
                                    <select asp-for="Country" id="country" class="tf-select" data-default="">
                                        <option value="---">Страна проживания</option>
                                        <option value="Allemagne">Allemagne</option>
                                        <option value="France">France</option>
                                        <option value="Néerlande">Néerlande</option>
                                        <option value="Espagne">Espagne</option>
                                        <option value="Portugal">Portugal</option>
                                        <option value="Pologne">Pologne</option>
                                        <option value="République Tchèque">République Tchèque</option>
                                        <option value="Hongrie">Hongrie</option>
                                        <option value="Bulgarie">Bulgarie</option>
                                        <option value="Croatie">Croatie</option>
                                        <option value="Italie">Italie</option>
                                        <option value="Belgique">Belgique</option>
                                        <option value="Suisse">Suisse</option>
                                        <option value="Luxembourg">Luxembourg</option>
                                        <option value="Autre">Autre</option>
                                    </select>
                                    <span asp-validation-for="Country" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="cols mb-20">
                                <input type="checkbox"
                                       id="agree"
                                       name="Agree"
                                       value="true"
                                       required
                                @(Model.Agree == "true" ? "checked" : "") />
                                <label for="agree">Я принимаю <a href="#" target="_blank">условия и положения</a>.</label>
                                <span asp-validation-for="Agree" class="text-danger"></span>
                            </div>

                            <button class="tf-btn style-default btn-color-secondary pd-40 boder-8" type="submit">
                                <span>Отправить заявку</span>
                            </button>
                        </form>

                        <div class="appointment-info">
                            <div class="info-content">
                                <h4>Подайте заявку на кредит онлайн</h4>
                                <p class="pricing-description">
                                    Мы всегда готовы помочь вам. Свяжитесь с нами сейчас
                                </p>
                                <div class="appointment-info">
                                    <div class="appointment-calculator-info">
                                        <h4 class="title">Информация о кредите</h4>
                                        <div class="appointment-details" id="appointment-details">
                                            <p>Для эффективной годовой процентной ставки (APR)<strong> 2.5 %</strong>,</p>
                                            <p>Чистая сумма кредита составляет <strong> <span id="appointment-amount-display">10 000</span> <span class="currency-symbol"> €</span> </strong> и общая сумма к возврату составляет<strong> <span id="total-amount">10 779.14</span> <span class="currency-symbol"> €</span></strong>.</p>
                                            <p>Ежемесячные сборы составляют <strong> <span id="monthly-payment">149.71</span> <span class="currency-symbol"> €</span> </strong> и срок кредита составляет <strong> <span id="appointment-duration">72</span> месяцев</strong>.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        const tauxInteretEffectif = 2.5;

        function formatNumber(num) {
            return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, " ");
        }

        function calculateEMI(principal, rate, time) {
            const monthlyRate = rate / (12 * 100);
            const emi = principal * monthlyRate * Math.pow(1 + monthlyRate, time) / (Math.pow(1 + monthlyRate, time) - 1);
            return emi;
        }

        function getCurrencySymbol(currencyCode) {
            const symbols = {
                'EUR': '€',
                'CHF': '₣',
                'USD': '$',
                'CAD': '$',
                'GBP': '£'
            };
            return symbols[currencyCode] || '€';
        }

        function updateAppointmentInfo() {
            const amount = parseFloat(document.getElementById('amount').value) || 10000;
            const period = parseInt(document.getElementById('period').value) || 72;
            const currency = document.getElementById('currency').value || 'EUR';
            const currencySymbol = getCurrencySymbol(currency);

            const monthlyRate = tauxInteretEffectif / (12 * 100);
            const emi = calculateEMI(amount, tauxInteretEffectif, period);
            const totalAmount = emi * period;

            document.getElementById('appointment-amount-display').textContent = formatNumber(amount.toFixed(0));
            document.getElementById('total-amount').textContent = formatNumber(totalAmount.toFixed(2));
            document.getElementById('monthly-payment').textContent = formatNumber(emi.toFixed(2));
            document.getElementById('appointment-duration').textContent = period;

            const currencySymbols = document.querySelectorAll('.currency-symbol');
            currencySymbols.forEach(symbol => {
                symbol.textContent = ' ' + currencySymbol;
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            const amountField = document.getElementById('amount');
            const periodField = document.getElementById('period');
            const currencyField = document.getElementById('currency');

            if (amountField) {
                amountField.addEventListener('input', updateAppointmentInfo);
            }
            if (periodField) {
                periodField.addEventListener('input', updateAppointmentInfo);
            }
            if (currencyField) {
                currencyField.addEventListener('change', updateAppointmentInfo);
            }

            updateAppointmentInfo();
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}