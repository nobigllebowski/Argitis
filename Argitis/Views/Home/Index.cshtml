@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Argitis.Resources.Views.Home.Index> Localizer

@model Argitis.Models.HomeViewModel

@{
    ViewData["Title"] = $"{Localizer["HomeTitle"]} - VeltisGroup";
    ViewData["MetaDescription"] = Model.MetaDescription;
    ViewData["MetaKeywords"] = Model.MetaKeywords;
}

@section Styles {
    <style>
        .wg-testimonial .bot {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 20px;
        }

            .wg-testimonial .bot .avatar img {
                border: 3px solid #fff;
                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            }

            .wg-testimonial .bot .info {
                text-align: left;
            }

        .wg-testimonial .avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: bold;
            font-size: 20px;
            margin-right: 15px;
            flex-shrink: 0;
        }
    </style>
}

<!-- .page-title -->
<div class="page-title-homepage-3">
    <div class="swiper-container slide-effect-fade slider-page-title-home">
        <div class="swiper-wrapper">
            <div class="swiper-slide">
                <img class="lazyload" data-src="~/images/sld2.jpg" src="~/images/sld2.jpg" alt="" asp-append-version="true">
                <div class="content-inner">
                    <div class="tf-container">
                        <div class="row">
                            <div class="col-12">
                                <div class="wrap-content">
                                    <div class="heading fade-item fade-item1">
                                        <h2 class="title text-white">@Localizer["HeroTitle1"]</h2>
                                        <p class="description text-white fade-item fade-item2">
                                            @Localizer["HeroDesc1"]
                                        </p>
                                    </div>
                                    <div class="fade-item fade-item3">
                                        <a class="tf-btn style-default btn-color-secondary pd-28" href="/Home/Appointment">
                                            <span>@Localizer["RequestCredit"] <i class="icon-ArrowRight arr-1"></i></span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="swiper-slide">
                <img class="lazyload" data-src="~/images/sld3.jpg" src="~/images/sld3.jpg" alt="" asp-append-version="true">
                <div class="content-inner">
                    <div class="tf-container">
                        <div class="row">
                            <div class="col-12">
                                <div class="wrap-content mx-auto text-center">
                                    <div class="heading fade-item fade-item1">
                                        <h2 class="title text-white">@Localizer["HeroTitle2"]</h2>
                                        <p class="description text-white fade-item fade-item2">
                                            @Localizer["HeroDesc2"]
                                        </p>
                                    </div>
                                    <div class="fade-item fade-item3">
                                        <a class="tf-btn style-default btn-color-secondary pd-28 mx-auto" href="/Home/Appointment">
                                            <span>@Localizer["RequestCredit"] <i class="icon-ArrowRight arr-1"></i></span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="swiper-slide">
                <img class="lazyload" data-src="~/images/sld1.jpg" src="~/images/sld1.jpg" alt="">
                <div class="content-inner">
                    <div class="tf-container">
                        <div class="row">
                            <div class="col-12">
                                <div class="wrap-content ml-auto text-end">
                                    <div class="heading">
                                        <h2 class="title text-white fade-item fade-item1">
                                            @Localizer["HeroTitle3"]
                                        </h2>
                                        <p class="description text-white fade-item fade-item2">
                                            @Localizer["HeroDesc3"]
                                        </p>
                                    </div>
                                    <div class="fade-item fade-item3">
                                        <a class="tf-btn style-default btn-color-secondary pd-28 ml-auto" href="/Home/Appointment">
                                            <span>@Localizer["RequestCredit"] <i class="icon-ArrowRight arr-1"></i></span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="swiper-pagination pagination-page-title-home"></div>
</div><!-- /.page-title -->
<!-- .main-content -->
<div class="main-content home-page-3">
    <!-- .section-box-about -->
    <div class="section-box-about page-home-3 tf-spacing-1">
        <div class="tf-container">
            <div class="wrap-box-about">
                <div class="row">
                    <div class="col-md-6">
                        <div class="box-about">
                            <div class="icon wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                <img src="~/images/favicon.png" alt="">
                            </div>
                            <div class="heading-section text-start">
                                <p class="text-2 sub wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                    @Localizer["AboutWho"]
                                </p>
                                <h3 class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                    @Localizer["AboutHead"]
                                </h3>
                                <p class="description text-1 lh-30 wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                    @Localizer["AboutDesc"]
                                </p>
                            </div>
                            <div class="wrap-counter layout-2">
                                <div class="counter-item has-icon">
                                    <div class="icon">
                                        <i class="icon-SketchLogo"></i>
                                    </div>
                                    <div class="count">
                                        <div class="counter-number">
                                            <div class="odometer style-1-1" data-value="@Model.ExperienceYears">0</div>
                                            <span class="sub">@Localizer["Years"]</span>
                                        </div>
                                        <p>@Localizer["YearsExp"]</p>
                                    </div>
                                </div>
                                <div class="counter-item has-icon">
                                    <div class="icon">
                                        <i class="icon-Smiley"></i>
                                    </div>
                                    <div class="count">
                                        <div class="counter-number">
                                            <div class="odometer style-1-2" data-value="@(Model.HappyClients / 1000)">0</div>
                                            <span class="sub">k</span>
                                        </div>
                                        <p>@Localizer["HappyClients"]</p>
                                    </div>
                                </div>
                                <div class="counter-item has-icon">
                                    <div class="icon">
                                        <i class="icon-HandHeart"></i>
                                    </div>
                                    <div class="count">
                                        <div class="counter-number">
                                            <div class="odometer style-1-3" data-value="@Model.Reviews">0</div>
                                        </div>
                                        <p>@Localizer["Reviews"]</p>
                                    </div>
                                </div>
                                <div class="counter-item has-icon">
                                    <div class="icon">
                                        <i class="icon-Certificate"></i>
                                    </div>
                                    <div class="count">
                                        <div class="counter-number">
                                            <div class="odometer style-1-4" data-value="@Model.Awards">0</div>
                                        </div>
                                        <p>@Localizer["Awards"]</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-5 offset-xl-1 offset-0">
                        <div class="image-wrap wow fadeInRight effec-overlay" data-wow-duration="1000" data-wow-delay="0s">
                            <img class="lazyload" data-src="~/images/abt.jpg" src="~/images/abt.jpg" alt="">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div> <!-- /.section-box-about -->
    <!-- section-service -->
    <section class="section-service tf-spacing-1">
        <div class="tf-container">
            <div class="row">
                <div class="col-12">
                    <div class="wrap-heading">
                        <div class="heading-section text-start">
                            <p class="text-2 sub wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                @Localizer["ServiceOffer"]
                            </p>
                            <h3 class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                @Localizer["ServiceTitle"]
                            </h3>
                            <p class="description text-1 lh-30 wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">@Localizer["ServiceDesc"]</p>
                        </div>
                        <a class="tf-btn style-default btn-color-white has-boder pd-26 wow fadeInUp" data-wow-duration="1000" data-wow-delay="0.1s" href="/Home/Services">
                            <span>@Localizer["SeeMore"]</span>
                        </a>
                    </div>
                    <div class="grid-layout-3 multi-item">
                        @foreach (var service in Model.Services)
                        {
                            <div class="service-item style-3 hover-img wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                <div class="content z-5">
                                    <h5 class="title">
                                        <a href="@service.Link">@service.Name</a>
                                    </h5>
                                    <p>@service.Description</p>
                                </div>
                                <div class="image-wrap z-5 relative">
                                    <a href="@service.Link">
                                        <img class="lazyload" data-src="@service.ImageUrl" src="@service.ImageUrl" alt="@service.Name">
                                    </a>
                                </div>
                                <a href="@service.Link" class="tf-btn-link z-5">
                                    <span data-text="@Localizer["ViewDetails"]">@Localizer["ViewDetails"]</span>
                                    <i class="icon-ArrowRight"></i>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section><!-- /section-service -->
    <!-- .section-process -->
    <section class="section-process home-page-3 tf-spacing-1">
        <div class="tf-container">
            <div class="row">
                <div class="col-md-4">
                    <div class="wrap-content">
                        <div class="heading-section text-start">
                            <p class="text-2 sub wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                @Localizer["LearnMore"]
                            </p>
                            <h3 class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                @Localizer["HowItWorks"]
                            </h3>
                            <p class="description text-1 lh-30 wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                @Localizer["ProcessDesc"]
                            </p>
                        </div>
                        <a class="tf-btn style-default btn-color-white has-boder pd-26 wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s" href="/Home/Contact">
                            <span>@Localizer["ProjectsReady"]</span>
                        </a>
                    </div>
                </div>
                <div class="col-md-7 offset-md-1 offset-0">
                    <div class="wrap-process list">
                        @foreach (var step in Model.ProcessSteps)
                        {
                            <div class="process-item style-no-line style-has-icon effec-icon wow fadeInRight" data-wow-duration="1000" data-wow-delay="0s">
                                <div class="item">
                                    <i class="@step.IconClass"></i>
                                    <span class="number">@step.StepNumber</span>
                                </div>
                                <div class="content">
                                    <h5 class="title"><a href="#">@step.Title</a></h5>
                                    <p>@step.Description</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section><!-- /.section-process -->
    <!-- .section-testimonials -->
    <section class="section-testimonials bg-1 home-page-3 tf-spacing-1">
        <div class="heading-section">
            <p class="text-2 sub wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                @Localizer["ReviewsTitle"]
            </p>
            <h3 class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                @Localizer["ReviewsHead"]
            </h3>
            <p class="description text-1 lh-30 wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s"></p>
        </div>
        <div class="swiper-container slider-testimonial-center">
            <div class="swiper-wrapper">
                @foreach (var testimonial in Model.Testimonials)
                {
                    <div class="swiper-slide">
                        <div class="wg-testimonial style-text-center">
                            <div class="rating">
                                <i class="icon-favorite_major"></i>
                                <i class="icon-favorite_major"></i>
                                <i class="icon-favorite_major"></i>
                                <i class="icon-favorite_major"></i>
                                <i class="icon-favorite_major"></i>
                            </div>
                            <div class="content">
                                <p class="text text-1 lh-30 fw-4 mb-16">
                                    "@testimonial.Quote"
                                </p>
                                <div class="bot">
                                    <div class="avatar">
                                        <img src="@testimonial.ImageUrl" alt="@testimonial.Author"
                                             style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover; margin-right: 15px;">
                                    </div>
                                    <div class="info">
                                        <h6 class="title">
                                            <a href="#">@testimonial.Author</a>
                                        </h6>
                                        <p>@testimonial.Role</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section><!-- /.section-testimonials -->
    <!-- .section-contact -->
    <section class="section-contact section-news tf-spacing-1 style-pagination">
        <div class="tf-container">
            <div class="row">
                <div class="col-12">
                    <div class="wrap-content">
                        <div class="box-contact">
                            <div class="heading-section text-start">
                                <p class="text-2 sub wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                    @Localizer["ContactReady"]
                                </p>
                                <h3 class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                    @Localizer["ContactHead"]
                                </h3>
                                <p class="description text-1 lh-30 wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s">
                                    @Localizer["ContactDesc"]
                                </p>
                            </div>
                            <ul class="list-info">
                                <li class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s"><i class="icon-Envelope"></i> <a href="mailto:@Model.Email">@Model.Email</a></li>
                                <li class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s"><i class="icon-PhoneCall"></i><a href="tel:@Model.Phone">@Model.Phone</a></li>
                                <li class="wow fadeInUp" data-wow-duration="1000" data-wow-delay="0s"><i class="icon-MapPin"></i>@Model.Address</li>
                            </ul>
                        </div>
                        <form class="form-consultation wow fadeInRight" data-wow-duration="1000" data-wow-delay="0s" method="post" asp-action="Appointment">
                            <h4 class="mb-20 text-center">@Localizer["RequestCredit"]</h4>
                            <fieldset class="name">
                                <input type="text" name="name" class="tf-input style-1" placeholder="@Localizer["NamePlaceholder"]" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <fieldset class="phone">
                                <input type="number" name="phone" class="tf-input style-1" placeholder="@Localizer["PhonePlaceholder"]" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <fieldset class="email">
                                <input type="email" name="email" class="tf-input style-1" placeholder="@Localizer["EmailPlaceholder"]" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <fieldset class="amount">
                                <input type="number" name="amount" class="tf-input style-1" placeholder="@Localizer["AmountPlaceholder"]" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <fieldset class="period">
                                <input type="text" name="period" class="tf-input style-1" placeholder="@Localizer["PeriodPlaceholder"]" tabindex="2" aria-required="true" required>
                            </fieldset>
                            <button class="tf-btn style-default btn-color-secondary pd-40 boder-8 send-wrap" type="submit">
                                <span>@Localizer["Confirm"]</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section> <!-- /.section-contact -->
    <!-- .section-faq -->
    <section class="section-faq tf-spacing-3">
        <div class="tf-container">
            <div class="row justify-center">
                <div class="col-md-8">
                    <div class="heading-section">
                        <p class="text-2 sub">@Localizer["FaqWhy"]</p>
                        <h3>@Localizer["FaqHead"]</h3>
                        <p class="description text-1 lh-30">
                            @Localizer["FaqDesc"]
                        </p>
                    </div>
                    <div class="tf-accordion" id="accordion">
                        @for (int i = 0; i < Model.FaqItems.Count; i++)
                        {
                            var item = Model.FaqItems[i];
                            var collapseId = $"collapse{i + 1}";
                            var isExpanded = item.IsExpanded ? "show" : "";
                            var expandedAttr = item.IsExpanded ? "true" : "false";

                            <div class="tf-accordion-item">
                                <div class="accordion-header">
                                    <h5 class="title @(item.IsExpanded ? "" : "collapsed")" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="@expandedAttr" aria-controls="@collapseId">
                                        @item.Question
                                        <span class="icon"></span>
                                    </h5>
                                </div>
                                <div id="@collapseId" class="accordion-collapse collapse @isExpanded" data-bs-parent="#accordion">
                                    <div class="tf-accordion-body">
                                        <p>@item.Answer</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section><!-- /.section-faq -->
</div>
<!-- /.main-content -->