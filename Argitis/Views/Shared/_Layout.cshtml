<!DOCTYPE html>
<!--[if IE 8]><html class="ie" xmlns="http://www.w3.org/1999/xhtml" xml:lang="@Context.Request.Cookies["lang"]" lang="@Context.Request.Cookies["lang"]"> <![endif]-->
<!--[if (gte IE 9)|!(IE)]><!-->
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="@Context.Request.Cookies["lang"]" lang="@Context.Request.Cookies["lang"]">
<!--<![endif]-->
<head>
    <!-- Meta Pixel Code -->
