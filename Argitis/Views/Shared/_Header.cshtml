@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Argitis.Resources.Views.Shared._Header> Localizer

<header id="header-main" class="header header-style-absolute header-default">
    <div class="header-inner">
        <div class="tf-container">
            <div class="row">
                <div class="col-12">
                    <div class="header-inner-wrap">
                        <div class="header-logo">
                            <a href="/" class="site-logo">
                                 @* <img id="logo_header" alt="" src="~/images/logo-white.png">  *@
                                <img id="logo_header" alt="VeltisGroup" src="~/images/logo-white.png">
                                @* <svg width="160" height="40" viewBox="0 0 160 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <text x="0" y="28" font-family="Arial, sans-serif" font-weight="700" font-size="28" fill="#ffffff" letter-spacing="2">Veltis</text>
                                    <text x="95" y="28" font-family="Arial, sans-serif" font-weight="300" font-size="28" fill="#ffffff" letter-spacing="1">Group</text>
                                    <rect x="0" y="35" width="40" height="3" fill="#ffffff" rx="1.5" />
                                </svg> *@
                            </a>
                        </div>
                        <div class="header-logo-2">
                            <a href="/" class="site-logo">
                                <img id="logo_header" alt="" src="~/images/logo.png">
                            </a>
                        </div>
                        <nav class="main-menu">
                            <ul class="navigation">
                                <li>
                                    <a href="/">@Localizer["Home"]</a>
                                </li>
                                <li>
                                    <a href="/Home/About">@Localizer["About"]</a>
                                </li>
                                <li>
                                    <a href="/Home/Services">@Localizer["Services"]</a>
                                </li>
                                <li>
                                    <a href="/Home/Contact">@Localizer["Contact"]</a>
                                </li>
                            </ul>
                        </nav>
                        <div class="header-right">
                            <!-- Language Selector (без рус/укр) -->
                            <div class="tf-languages">
                                <div class="tf-dropdown-sort" data-bs-toggle="dropdown">
                                    <div class="btn-select">
                                        <span class="text-sort-value">
                                            <img src="~/images/@(Context.Request.Cookies["lang"] ?? "en").jpg" alt="@Context.Request.Cookies["lang"]" class="flag-icon">
                                            <span class="lang-text">@(Context.Request.Cookies["lang"]?.ToUpper() ?? "EN")</span>
                                            <i class="icon-CaretDown"></i>
                                        </span>
                                    </div>
                                    <div class="dropdown-menu">
                                        <div class="select-item" data-lang="fr">
                                            <img src="~/images/fr.jpg" alt="Français" class="flag-icon">
                                            <span class="text-value-item">Français</span>
                                        </div>
                                        <div class="select-item" data-lang="en">
                                            <img src="~/images/en.jpg" alt="English" class="flag-icon">
                                            <span class="text-value-item">English</span>
                                        </div>
                                        <div class="select-item" data-lang="de">
                                            <img src="~/images/de.jpg" alt="Deutsch" class="flag-icon">
                                            <span class="text-value-item">Deutsch</span>
                                        </div>
                                        <div class="select-item" data-lang="es">
                                            <img src="~/images/es.jpg" alt="Español" class="flag-icon">
                                            <span class="text-value-item">Español</span>
                                        </div>
                                        <div class="select-item" data-lang="fi">
                                            <img src="~/images/fi.jpg" alt="Suomi" class="flag-icon">
                                            <span class="text-value-item">Suomi</span>
                                        </div>
                                        <div class="select-item" data-lang="hr">
                                            <img src="~/images/hr.jpg" alt="Hrvatski" class="flag-icon">
                                            <span class="text-value-item">Hrvatski</span>
                                        </div>
                                        <div class="select-item" data-lang="it">
                                            <img src="~/images/it.jpg" alt="Italiano" class="flag-icon">
                                            <span class="text-value-item">Italiano</span>
                                        </div>
                                        <div class="select-item" data-lang="lt">
                                            <img src="~/images/lt.jpg" alt="Lietuvių" class="flag-icon">
                                            <span class="text-value-item">Lietuvių</span>
                                        </div>
                                        <div class="select-item" data-lang="lv">
                                            <img src="~/images/lv.jpg" alt="Latviešu" class="flag-icon">
                                            <span class="text-value-item">Latviešu</span>
                                        </div>
                                        <div class="select-item" data-lang="mt">
                                            <img src="~/images/mt.jpg" alt="Malti" class="flag-icon">
                                            <span class="text-value-item">Malti</span>
                                        </div>
                                        <div class="select-item" data-lang="nl">
                                            <img src="~/images/nl.jpg" alt="Nederlands" class="flag-icon">
                                            <span class="text-value-item">Nederlands</span>
                                        </div>
                                        <div class="select-item" data-lang="pl">
                                            <img src="~/images/pl.jpg" alt="Polski" class="flag-icon">
                                            <span class="text-value-item">Polski</span>
                                        </div>
                                        <div class="select-item" data-lang="pt">
                                            <img src="~/images/pt.jpg" alt="Português" class="flag-icon">
                                            <span class="text-value-item">Português</span>
                                        </div>
                                        <div class="select-item" data-lang="ro">
                                            <img src="~/images/ro.jpg" alt="Română" class="flag-icon">
                                            <span class="text-value-item">Română</span>
                                        </div>
                                        <div class="select-item" data-lang="sk">
                                            <img src="~/images/sk.jpg" alt="Slovenčina" class="flag-icon">
                                            <span class="text-value-item">Slovenčina</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="group-btn">
                                <!-- кнопки поиска и корзины -->
                            </div>
                            <div class="btn-get">
                                <a class="tf-btn style-default btn-color-secondary pd-40" href="/Home/Appointment">
                                    <span>@Localizer["RequestCredit"]</span>
                                </a>
                            </div>
                            <div class="mobile-button" data-bs-toggle="offcanvas" data-bs-target="#menu-mobile" aria-controls="menu-mobile">
                                <i class="icon-menu"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const languageItems = document.querySelectorAll('.tf-languages .select-item');
        
        languageItems.forEach(function (item) {
            item.addEventListener('click', function () {
                const lang = this.getAttribute('data-lang');
                const currentUrl = window.location.pathname + window.location.search;
                
                // Создаем форму и отправляем POST запрос
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/Language/ChangeLanguage';
                form.style.display = 'none';
                
                const langInput = document.createElement('input');
                langInput.type = 'hidden';
                langInput.name = 'lang';
                langInput.value = lang;
                
                const urlInput = document.createElement('input');
                urlInput.type = 'hidden';
                urlInput.name = 'returnUrl';
                urlInput.value = currentUrl;
                
                form.appendChild(langInput);
                form.appendChild(urlInput);
                document.body.appendChild(form);
                form.submit();
            });
        });
    });
</script>