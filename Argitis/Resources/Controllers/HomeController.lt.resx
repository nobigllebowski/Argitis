	<data name="Testimonial1Role" xml:space="preserve"><value>Mokytoja</value></data>
	<data name="Testimonial2Quote" xml:space="preserve"><value>Konsolidavau savo paskolas ir dabar turiu mėnesinę įmoką, atitinkančią mano biudžetą. Ačiū visai komandai už jų palaikymą!</value></data>
	<data name="Testimonial2Author" xml:space="preserve"><value>Ponas Martin</value></data>
	<data name="Testimonial2Role" xml:space="preserve"><value>Buhalteris</value></data>
	<data name="Testimonial3Quote" xml:space="preserve"><value>Klientų aptarnavimas buvo puikus. Personalas buvo draugiškas ir atsakė į visus mano klausimus.</value></data>
	<data name="Testimonial3Author" xml:space="preserve"><value>Ponas Bernard</value></data>
	<data name="Testimonial3Role" xml:space="preserve"><value>Vairuotojas</value></data>
	<data name="Testimonial4Quote" xml:space="preserve"><value>Man patiko paslaugos skaidrumas ir greitis. VELTISGROUP mane palaikė kiekviename mano paskolos paraiškos etape.</value></data>
	<data name="Testimonial4Author" xml:space="preserve"><value>Michael L.</value></data>
	<data name="Testimonial4Role" xml:space="preserve"><value>Pardavimų atstovas</value></data>
	<data name="Testimonial5Quote" xml:space="preserve"><value>Labai greitas patvirtinimas ir patogi paslauga. Rekomenduoju visiems!</value></data>
	<data name="Testimonial5Author" xml:space="preserve"><value>Anna K.</value></data>
	<data name="Testimonial5Role" xml:space="preserve"><value>Dizainerė</value></data>
	<data name="Testimonial6Quote" xml:space="preserve"><value>Ačiū komandai už pagalbą su hipoteka. Procesas buvo skaidrus ir greitas.</value></data>
	<data name="Testimonial6Author" xml:space="preserve"><value>Dmitry S.</value></data>
	<data name="Testimonial6Role" xml:space="preserve"><value>Inžinierius</value></data>

