	<data name="Testimonial2Quote" xml:space="preserve"><value>Konsolidirao sam svoje kredite i sada imam mjesečnu uplatu koja odgovara mom budžetu. Hvala cijelom timu na podršci!</value></data>
	<data name="Testimonial2Author" xml:space="preserve"><value>Gospodin Martin</value></data>
	<data name="Testimonial2Role" xml:space="preserve"><value>Računovođa</value></data>
