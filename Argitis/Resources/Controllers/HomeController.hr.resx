	<data name="Testimonial3Author" xml:space="preserve"><value>Gospodin Bernard</value></data>
	<data name="Testimonial3Role" xml:space="preserve"><value>Vozač</value></data>
	<data name="Testimonial4Quote" xml:space="preserve"><value>Sviđala mi se transparentnost i brzina usluge. GROUPE-ARGITIS me podržao u svakoj fazi moje prijave za kredit.</value></data>
	<data name="Testimonial4Author" xml:space="preserve"><value>Michael L.</value></data>
	<data name="Testimonial4Role" xml:space="preserve"><value>Prodajni predstavnik</value></data>
	<data name="Testimonial5Quote" xml:space="preserve"><value>Vrlo brzo odobrenje i praktična usluga. Preporučujem svima!</value></data>
	<data name="Testimonial5Author" xml:space="preserve"><value>Anna K.</value></data>
	<data name="Testimonial5Role" xml:space="preserve"><value>Dizajnerica</value></data>
	<data name="Testimonial6Quote" xml:space="preserve"><value>Hvala timu na pomoći oko hipoteke. Proces je bio transparentan i brz.</value></data>
	<data name="Testimonial6Author" xml:space="preserve"><value>Dmitry S.</value></data>
	<data name="Testimonial6Role" xml:space="preserve"><value>Inženjer</value></data>

